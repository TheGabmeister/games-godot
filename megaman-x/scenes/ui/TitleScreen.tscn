[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/ui/title_screen.gd" id="1_title_screen"]
[ext_resource type="Texture2D" path="res://assets/placeholders/ui/title_banner.svg" id="2_title_banner"]

[node name="TitleScreen" type="Control"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_title_screen")

[node name="Background" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.0470588, 0.0784314, 0.137255, 1)

[node name="CenterContainer" type="CenterContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="CenterContainer"]
theme_override_constants/separation = 18
alignment = 1

[node name="Banner" type="TextureRect" parent="CenterContainer/VBoxContainer"]
texture = ExtResource("2_title_banner")

[node name="TitleLabel" type="Label" parent="CenterContainer/VBoxContainer"]
horizontal_alignment = 1
theme_override_colors/font_color = Color(0.92549, 0.952941, 1, 1)
text = "Campaign Runtime Shell"

[node name="BodyLabel" type="Label" parent="CenterContainer/VBoxContainer"]
horizontal_alignment = 1
theme_override_colors/font_color = Color(0.733333, 0.8, 0.901961, 1)
text = "New Game begins in Intro Highway.\nContinue resumes the campaign into Intro Highway or Stage Select depending on saved progression."

[node name="RegisteredStagesLabel" type="Label" parent="CenterContainer/VBoxContainer"]
horizontal_alignment = 1
theme_override_colors/font_color = Color(0.607843, 0.701961, 0.827451, 1)
text = "Registered stages: loading..."

[node name="SaveStatusLabel" type="Label" parent="CenterContainer/VBoxContainer"]
horizontal_alignment = 1
theme_override_colors/font_color = Color(0.839216, 0.901961, 0.980392, 1)
text = "Save data: loading..."

[node name="NewGameButton" type="Button" parent="CenterContainer/VBoxContainer"]
custom_minimum_size = Vector2(280, 52)
