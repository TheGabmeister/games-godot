[node name="ContinueButton" type="Button" parent="CenterContainer/VBoxContainer"]
custom_minimum_size = Vector2(280, 52)
text = "Continue Save"

[node name="StageSelectButton" type="Button" parent="CenterContainer/VBoxContainer"]
